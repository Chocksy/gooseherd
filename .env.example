# App branding (customizes dashboard title, commit prefix, branch prefix, etc.)
APP_NAME=Gooseherd

# Slack (required)
SLACK_BOT_TOKEN=xoxb-...
SLACK_APP_TOKEN=xapp-...
SLACK_SIGNING_SECRET=...
# Display name used in help/status hints (defaults to lowercase APP_NAME)
SLACK_COMMAND_NAME=gooseherd

# GitHub — use EITHER a PAT or GitHub App credentials (not both)
# Option A: Personal Access Token
GITHUB_TOKEN=ghp_...
# Option B: GitHub App (recommended for organizations)
GITHUB_APP_ID=
# PEM contents: single-line with literal \n escapes, or set via file:
# GITHUB_APP_PRIVATE_KEY="-----BEGIN RSA PRIVATE KEY-----\nMIIE...\n-----END RSA PRIVATE KEY-----"
GITHUB_APP_PRIVATE_KEY=
GITHUB_APP_INSTALLATION_ID=
GITHUB_DEFAULT_OWNER=hubstaff

# Team → Slack channel mapping (optional, JSON format)
# Maps team names to channel IDs for team tagging on runs.
# TEAM_CHANNEL_MAP={"platform":["C123","C456"],"product":["C789"]}

# Goose + OpenRouter (optional, only needed when AGENT_COMMAND_TEMPLATE uses goose)
OPENROUTER_API_KEY=
GOOSE_PROVIDER=openrouter
GOOSE_MODEL=

# Comma-separated allowlist. Example: hubstaff/hubstaff-server,hubstaff/another-repo
REPO_ALLOWLIST=

# Runtime
RUNNER_CONCURRENCY=1
WORK_ROOT=.work
DATA_DIR=data
DRY_RUN=true

# Optional branch controls (defaults to lowercase APP_NAME)
BRANCH_PREFIX=gooseherd
DEFAULT_BASE_BRANCH=main

# Git identity for commits (defaults to "${APP_NAME} Bot")
GIT_AUTHOR_NAME=Gooseherd Bot
GIT_AUTHOR_EMAIL=gooseherd-bot@local

# Command templates
# Placeholders: {{repo_dir}} {{prompt_file}} {{run_id}} {{repo_slug}} {{task_file}} {{parent_run_id}}
AGENT_COMMAND_TEMPLATE=bash scripts/dummy-agent.sh {{repo_dir}} {{prompt_file}} {{run_id}}
# Goose example (fresh runs use named sessions, follow-ups fork from parent):
# AGENT_COMMAND_TEMPLATE=cd {{repo_dir}} && goose run -n gooseherd-{{run_id}} --no-profile --with-builtin developer,todo --debug --max-turns 60 --max-tool-repetitions 6 --provider openrouter --model $GOOSE_MODEL -i {{prompt_file}}
# Goose follow-up template (uses {{parent_run_id}} to fork session history):
# AGENT_FOLLOW_UP_TEMPLATE=cd {{repo_dir}} && goose run -n gooseherd-{{run_id}} --fork gooseherd-{{parent_run_id}} --no-profile --with-builtin developer,todo --debug --max-turns 60 --max-tool-repetitions 6 --provider openrouter --model $GOOSE_MODEL -i {{prompt_file}}

# Optional. Leave empty to skip validation.
# Placeholders: {{repo_dir}} {{run_id}} {{repo_slug}}
VALIDATION_COMMAND=

# Optional lint auto-fix (runs before validation, "free" round — no agent re-run needed)
# Example: cd {{repo_dir}} && npm run lint:fix
LINT_FIX_COMMAND=

# How many times to re-run the agent to fix validation errors (0 = fail immediately)
MAX_VALIDATION_ROUNDS=2

# Max time for AGENT_COMMAND_TEMPLATE in seconds
AGENT_TIMEOUT_SECONDS=1200

# Slack run-card heartbeat cadence (seconds)
SLACK_PROGRESS_HEARTBEAT_SECONDS=20

# Dashboard
DASHBOARD_ENABLED=true
# Use 127.0.0.1 for local dev, 0.0.0.0 for Docker/Coolify (set in Dockerfile ENV)
DASHBOARD_HOST=127.0.0.1
DASHBOARD_PORT=8787
# DASHBOARD_PUBLIC_URL=https://gooseherd.example.com
# Set DASHBOARD_TOKEN to require authentication (recommended for non-localhost)
DASHBOARD_TOKEN=

# Optional channel allowlist for Slack (comma-separated channel IDs)
SLACK_ALLOWED_CHANNELS=

# Guards
MAX_TASK_CHARS=4000

# Workspace Cleanup (auto-deletes old run directories from .work/)
WORKSPACE_CLEANUP_ENABLED=true
WORKSPACE_MAX_AGE_HOURS=24
WORKSPACE_CLEANUP_INTERVAL_MINUTES=30

# CEMS Memory Integration (optional, disabled by default)
CEMS_ENABLED=false
CEMS_API_URL=http://localhost:8100
CEMS_API_KEY=

# CEMS MCP Extension for Goose agents (optional, provides live memory tools during agent runs)
# Install CEMS first: CEMS_TOOL=goose curl -sSf https://raw.githubusercontent.com/chocksy/cems/main/remote-install.sh | bash
# Then set the command (env vars are passed through to the stdio server):
# CEMS_MCP_COMMAND=CEMS_API_URL=$CEMS_API_URL CEMS_API_KEY=$CEMS_API_KEY cems-mcp
# In Docker: leave empty — Gooseherd's HTTP-based CemsProvider handles memory integration.
CEMS_MCP_COMMAND=

# Pipeline — which YAML pipeline to use (see pipelines/ directory)
PIPELINE_FILE=pipelines/default.yml

# Observer / Trigger System (optional, disabled by default)
# Watches external sources (Sentry, GitHub webhooks, Slack channels) and auto-triggers runs.
OBSERVER_ENABLED=false
# Slack channel where observer posts seed messages and approval requests
OBSERVER_ALERT_CHANNEL_ID=
# Daily budget caps
OBSERVER_MAX_RUNS_PER_DAY=50
OBSERVER_MAX_RUNS_PER_REPO_PER_DAY=5
# Cooldown between runs for the same dedup key (minutes)
OBSERVER_COOLDOWN_MINUTES=60
# Trigger rules YAML file path
OBSERVER_RULES_FILE=observer-rules/default.yml
# Sentry project → repo mapping: "sentry-project:owner/repo,project2:owner/repo2"
OBSERVER_REPO_MAP=

# Sentry Poller (optional, requires OBSERVER_ENABLED=true)
SENTRY_AUTH_TOKEN=
SENTRY_ORG_SLUG=
# Sentry poll interval (seconds)
OBSERVER_SENTRY_POLL_INTERVAL_SECONDS=300

# GitHub Webhook Receiver (optional, requires OBSERVER_ENABLED=true)
# Set this to enable HMAC signature verification for incoming GitHub webhooks
OBSERVER_GITHUB_WEBHOOK_SECRET=
# Webhook server port (separate from dashboard)
OBSERVER_WEBHOOK_PORT=9090

# CI Feedback Loop (optional, disabled by default)
# When enabled, the pipeline waits for GitHub Actions CI after push, then auto-fixes failures.
CI_WAIT_ENABLED=false
CI_POLL_INTERVAL_SECONDS=30
# Patience window: how long to wait for check suites to appear (seconds)
CI_PATIENCE_TIMEOUT_SECONDS=300
# Max total wait for CI completion (seconds, starts AFTER patience window)
CI_MAX_WAIT_SECONDS=1800
# Comma-separated check run name filter (empty = all checks). Case-insensitive substring match.
CI_CHECK_FILTER=
# Max agent fix rounds before giving up (on_exhausted: complete_with_warning)
CI_MAX_FIX_ROUNDS=2

# LLM via OpenRouter (used for scope_judge, plan_task, smart observer triage)
# Same key as Goose if you use OpenRouter as provider — no separate Anthropic key needed.
# OPENROUTER_API_KEY is already defined above for Goose; quality gates reuse it.

# Plan Task — LLM-powered planning step before agent implementation (optional)
# Uses OPENROUTER_API_KEY. Skips gracefully if no key is set.
PLAN_TASK_MODEL=anthropic/claude-haiku-4-5

# Scope Judge — LLM-as-judge that compares diff vs task (optional, disabled by default)
# Runs after security_scan, before commit. Catches scope creep and unrelated changes.
SCOPE_JUDGE_ENABLED=false
SCOPE_JUDGE_MODEL=anthropic/claude-haiku-4-5
SCOPE_JUDGE_MIN_PASS_SCORE=60

# Smart Observer Triage — LLM-powered event classification (optional, disabled by default)
# When enabled, uses LLM to classify incoming events after rule matching.
# Falls back to rule-based routing on timeout or error.
OBSERVER_SMART_TRIAGE_ENABLED=false
OBSERVER_SMART_TRIAGE_MODEL=anthropic/claude-haiku-4-5
OBSERVER_SMART_TRIAGE_TIMEOUT_MS=10000

# Deploy Preview + Browser Verify (optional, disabled by default)
# Strategy is configured in pipeline YAML (deploy_preview node config).
# See docs/research-deploy-preview.md for strategy options:
#   url_pattern, github_deployment_api, command
BROWSER_VERIFY_ENABLED=false
SCREENSHOT_ENABLED=false

# Slack Channel Watcher (optional, requires OBSERVER_ENABLED=true)
# Watch alert channels and forward to observer
OBSERVER_SLACK_WATCHED_CHANNELS=
OBSERVER_SLACK_BOT_ALLOWLIST=

# Sentry Webhook Receiver (optional, requires OBSERVER_ENABLED=true)
# HMAC secret for validating Sentry webhook payloads
OBSERVER_SENTRY_WEBHOOK_SECRET=

# GitHub Poller (optional, requires OBSERVER_ENABLED=true)
# Poll for failed GitHub Actions on watched repos
OBSERVER_GITHUB_POLL_INTERVAL_SECONDS=300
OBSERVER_GITHUB_WATCHED_REPOS=

# Local Test Command (optional, runs before validation)
LOCAL_TEST_COMMAND=

# CEMS Team ID (optional)
CEMS_TEAM_ID=

# MCP Extensions (comma-separated, passed to goose as --with-extension)
MCP_EXTENSIONS=

# Sandbox — Docker container isolation for agent runs (optional, disabled by default)
# Uses Docker-out-of-Docker: the orchestrator spawns sibling sandbox containers.
SANDBOX_ENABLED=false
SANDBOX_IMAGE=gooseherd/sandbox:default
# Host-side absolute path that maps to WORK_ROOT. Required when SANDBOX_ENABLED=true.
# Must be the same physical directory as WORK_ROOT seen from the host (for DooD bind mounts).
SANDBOX_HOST_WORK_PATH=
# Resource limits per sandbox container
SANDBOX_CPUS=2
SANDBOX_MEMORY_MB=4096
